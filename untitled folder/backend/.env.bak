# Database
DATABASE_URL=postgresql://user:password@localhost:5432/simplif_iq

# APIs
GEMINI_API_KEY=your_gemini_key
OPENAI_API_KEY=your_openai_key
TAVILY_API_KEY=your_tavily_key
SENDGRID_API_KEY=your_sendgrid_key

# Email
FROM_EMAIL=noreply@simplif-iq.com
SUPPORT_EMAIL=support@simplif-iq.com

# Frontend
FRONTEND_URL=http://localhost:5173

# Google APIs (Optional — leave blank to skip Sheets/Drive integrations)
# Path to a service-account JSON key with edit access to the sheet + drive folder.
GOOGLE_SERVICE_ACCOUNT_FILE=./credentials/service_account.json
# Spreadsheet that will receive an appended row per lead.
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_SHEET_NAME=Leads
# Drive folder ID where generated PDFs are archived.
GOOGLE_DRIVE_FOLDER_ID=

# Environment
ENVIRONMENT=development
